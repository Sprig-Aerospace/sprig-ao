# Development symlinks (created per-worktree, not committed)
packages/web/agent-orchestrator.yaml

# Local agent orchestrator config (may contain secrets)
agent-orchestrator.yaml

# Agent configuration and activity logs
# .claude/ contents are ignored EXCEPT for the orchestrator scaffolding
# (agents, commands, hooks, settings.json). Per-developer state
# (settings.local.json, tdd-guard runtime data, etc.) stays local.
.claude/*
!.claude/agents/
!.claude/commands/
!.claude/hooks/
!.claude/settings.json
.opencode/
.ao/

# OS-specific files
.DS_Store
Thumbs.db
package-lock.json
